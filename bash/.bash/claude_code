#!/usr/bin/env bash
# Claude Code Dual-Mode Setup: Local Ollama + Cloud Anthropic
# Machine-specific tuning (GPU IDs, model sizes, CUDA libs) lives in
# ~/.bash/claude_code.local — deployed by the machine's own stow package.
# Source from ~/.bashrc or ~/.zshrc

# ── OLLAMA SERVER SETTINGS ────────────────────────────────────────────────────
export OLLAMA_HOST="127.0.0.1:11434"
export OLLAMA_KEEP_ALIVE="10m"
export OLLAMA_NUM_PARALLEL="1"
export OLLAMA_MAX_LOADED_MODELS="1"

# ── MODEL DEFAULTS (overridden per-machine in claude_code.local) ──────────────
OLLAMA_DEFAULT_MODEL="qwen2.5-coder:7b"
OLLAMA_LIGHT_MODEL="qwen2.5-coder:7b"
OLLAMA_PLAN_MODEL="qwen2.5-coder:7b"
OLLAMA_EXEC_MODEL="qwen2.5-coder:7b"

# ── LOCAL CLAUDE FUNCTIONS ────────────────────────────────────────────────────

claude-local() {
    # Local Ollama — full context, default model (requires 2 GPUs)
    local model="${1:-$OLLAMA_DEFAULT_MODEL}"
    ANTHROPIC_AUTH_TOKEN=ollama \
    ANTHROPIC_BASE_URL="http://${OLLAMA_HOST}" \
    ANTHROPIC_API_KEY="" \
    CLAUDE_LOCAL_GPUS=2 \
    claude --model "$model" "${@:2}"
}

claude-local-light() {
    # Local Ollama — single-GPU model (8.9 GB); use when GPU 2 is needed for HPC jobs
    ANTHROPIC_AUTH_TOKEN=ollama \
    ANTHROPIC_BASE_URL="http://${OLLAMA_HOST}" \
    ANTHROPIC_API_KEY="" \
    CLAUDE_LOCAL_GPUS=1 \
    claude --model "$OLLAMA_LIGHT_MODEL" "$@"
}

claude-local-plan() {
    # Local plan mode: starts with architect for planning.
    # When ready to implement, switch mid-session with: /model plan-executor
    # Run ollama-plan-setup once to register the short-name aliases.
    printf '\n=== LOCAL PLAN MODE ===\n'
    printf '  ARCHITECT : plan-architect  (%s)\n' "$OLLAMA_PLAN_MODEL"
    printf '  EXECUTOR  : plan-executor   (%s)\n' "$OLLAMA_EXEC_MODEL"
    printf '\nSwitch to executor when ready:\n'
    printf '  /model plan-executor\n\n'
    ANTHROPIC_AUTH_TOKEN=ollama \
    ANTHROPIC_BASE_URL="http://${OLLAMA_HOST}" \
    ANTHROPIC_API_KEY="" \
    CLAUDE_LOCAL_GPUS=2 \
    claude --model "plan-architect" "$@"
}

ollama-plan-setup() {
    # Register short-name aliases for plan-mode models (run once after ollama-start)
    local tmpfile
    tmpfile=$(mktemp /tmp/Modelfile.XXXXXX)

    printf 'FROM %s\n' "$OLLAMA_PLAN_MODEL" > "$tmpfile"
    ollama create plan-architect -f "$tmpfile" \
        && printf 'Created: plan-architect → %s\n' "$OLLAMA_PLAN_MODEL"

    printf 'FROM %s\n' "$OLLAMA_EXEC_MODEL" > "$tmpfile"
    ollama create plan-executor -f "$tmpfile" \
        && printf 'Created: plan-executor  → %s\n' "$OLLAMA_EXEC_MODEL"

    rm -f "$tmpfile"
    printf '\nUse /model plan-executor inside a session to switch.\n'
}

claude-local-exec() {
    # Local executor only — skips planning, jumps straight to implementer model
    ANTHROPIC_AUTH_TOKEN=ollama \
    ANTHROPIC_BASE_URL="http://${OLLAMA_HOST}" \
    ANTHROPIC_API_KEY="" \
    CLAUDE_LOCAL_GPUS=2 \
    claude --model "$OLLAMA_EXEC_MODEL" "$@"
}

# ── CLOUD CLAUDE FUNCTIONS ────────────────────────────────────────────────────

claude-sonnet() { claude --model "sonnet" "$@"; }
claude-opus()   { claude --model "opus" "$@"; }
claude-plan()   { claude --permission-mode plan --model "opusplan" "$@"; }  # read-only plan (Opus) → auto-switch to Sonnet on execute

# ── OPENROUTER FUNCTIONS ──────────────────────────────────────────────────────
# Requires OPENROUTER_API_KEY in the environment (set in ~/.bash/exports or ~/.env)

OPENROUTER_DEFAULT_MODEL="qwen/qwen3.6-plus-preview:free"

claude-openrouter() {
    # OpenRouter cloud API — Anthropic-compatible endpoint, free-tier models
    local model="${1:-$OPENROUTER_DEFAULT_MODEL}"
    local key="${OPENROUTER_API_KEY:-$(cat "$HOME/.openrouter-ai-key" 2>/dev/null)}"
    if [[ -z "$key" ]]; then
        echo "Error: no OpenRouter API key found (set OPENROUTER_API_KEY or place it in ~/.openrouter-ai-key)" >&2
        return 1
    fi
    ANTHROPIC_AUTH_TOKEN="$key" \
    ANTHROPIC_BASE_URL="https://openrouter.ai/api" \
    ANTHROPIC_API_KEY="" \
    claude --model "$model" "${@:2}"
}

# ── Z.AI FUNCTIONS ───────────────────────────────────────────────────────
# models from Z.ai (https://docs.z.ai/devpack/tool/claude)
# API key is configured in ~/.z-ai-key

ZAI_DEFAULT_MODEL="glm-5-turbo"  # Maps to ANTHROPIC_DEFAULT_SONNET_MODEL

claude-zai() {
    # Z.ai endpoint
    # Models: glm-4.5-air (Haiku), glm-5-turbo (Sonnet), glm-5.1 (Opus)
    local model="${1:-$ZAI_DEFAULT_MODEL}"
    local key="${ZAI_API_KEY:-$(cat "$HOME/.z-ai-key" 2>/dev/null)}"
    if [[ -z "$key" ]]; then
        echo "Error: no Z.ai API key found (set ZAI_API_KEY or place it in ~/.z-ai-key)" >&2
        return 1
    fi
    ANTHROPIC_AUTH_TOKEN="$key" \
    ANTHROPIC_BASE_URL="https://api.z.ai/api/anthropic" \
    ANTHROPIC_API_KEY="" \
    claude --model "$model" "${@:2}"
}

# Short aliases for specific Z.ai models
claude-zai-fast()   { claude-zai "glm-4.5-air" "$@"; } # Fastest
claude-zai-turbo()  { claude-zai "glm-5-turbo" "$@"; } # Balanced (default)
claude-zai-premium(){ claude-zai "glm-5.1" "$@"; }     # Highest quality

# ── OLLAMA SERVICE MANAGEMENT ─────────────────────────────────────────────────

ollama-start() {
    # Start Ollama pinned to a specific GPU (defaults to OLLAMA_GPU_UUID)
    local gpu="${OLLAMA_GPU_UUID:-${1:-$OLLAMA_GPU_ID}}"
    echo "Starting Ollama on GPU: $gpu"
    CUDA_VISIBLE_DEVICES="$gpu" ollama serve &
    disown
    sleep 2
    echo "Ollama running at http://${OLLAMA_HOST}"
}

ollama-start-multi() {
    # Start Ollama on ALL GPUs (needed for models > 12GB like qwen3.5:latest)
    echo "Starting Ollama on ALL GPUs — do not run HPC jobs concurrently"
    ollama serve &
    disown
    sleep 2
    echo "Ollama running at http://${OLLAMA_HOST}"
}

ollama-stop() {
    pkill -f "ollama serve" 2>/dev/null && echo "Ollama stopped." || echo "Ollama not running."
}

ollama-restart() {
    ollama-stop
    sleep 1
    ollama-start "$@"
}

ollama-status() {
    echo "=== Ollama Process ==="
    pgrep -a "ollama" || echo "Not running"
    echo ""
    echo "=== Loaded Models ==="
    curl -s "http://${OLLAMA_HOST}/api/ps" 2>/dev/null | python3 -m json.tool 2>/dev/null || echo "Cannot reach Ollama"
    echo ""
    echo "=== GPU Status ==="
    nvidia-smi --query-gpu=index,name,memory.used,memory.total,utilization.gpu \
               --format=csv,noheader,nounits 2>/dev/null || echo "nvidia-smi not available"
}

# ── MODEL HELPERS ─────────────────────────────────────────────────────────────

ollama-pull() {
    local model="${1:-$OLLAMA_DEFAULT_MODEL}"
    echo "Pulling: $model"
    ollama pull "$model"
}

ollama-create-64k() {
    # Create a 64K-capped variant — predictable RAM when running HPC jobs in parallel
    local model="${1:-$OLLAMA_DEFAULT_MODEL}"
    local variant="${model}-64k"
    local tmpfile
    tmpfile=$(mktemp /tmp/Modelfile.XXXXXX)
    cat > "$tmpfile" <<EOF
FROM $model
PARAMETER num_ctx 65536
EOF
    ollama create "$variant" -f "$tmpfile"
    rm -f "$tmpfile"
    echo "Created: $variant  (use with: claude-local $variant)"
}

ollama-models() {
    local output
    output=$(ollama list 2>/dev/null) || { echo "Ollama not running. Start with: ollama-start"; return 1; }

    local header lines
    header=$(printf '%s\n' "$output" | head -1)
    lines=$(printf '%s\n' "$output" | tail -n +2)
    [[ -z "$lines" ]] && { printf '%s\n' "$header"; echo "(no models)"; return 0; }

    printf '%s\n' "$header"
    local cat matched
    for cat in cloud embedding plan exec; do
        matched=$(printf '%s\n' "$lines" | awk -v c="$cat" '$1 ~ "[-:]"c"$"')
        [[ -n "$matched" ]] && printf '\n  [%s]\n%s\n' "$cat" "$matched"
    done

    matched=$(printf '%s\n' "$lines" | awk '$1 !~ "[-:](cloud|embedding|plan|exec)$"')
    [[ -n "$matched" ]] && printf '\n  [misc]\n%s\n' "$matched"
}

ollama-rename() {
    # Rename an Ollama model with exact casing, bypassing ollama cp inheritance quirk.
    # Uses the existing modelfile (with its blob SHA) so local-only models work too.
    # Usage: ollama-rename <old-name> <new-name>
    if [[ $# -ne 2 ]]; then
        echo "Usage: ollama-rename <old-name> <new-name>" >&2
        return 1
    fi
    local old="$1" new="$2"
    local tmpfile
    tmpfile=$(mktemp /tmp/Modelfile.XXXXXX)
    if ! ollama show "$old" --modelfile > "$tmpfile" 2>/dev/null && \
       ! ollama show --modelfile "$old" > "$tmpfile" 2>/dev/null; then
        echo "Error: model '$old' not found. Available models:" >&2
        ollama list >&2
        rm -f "$tmpfile"
        return 1
    fi
    if ollama create "$new" -f "$tmpfile"; then
        ollama rm "$old"
    else
        echo "Error: failed to create '$new' — '$old' was not removed." >&2
        rm -f "$tmpfile"
        return 1
    fi
    rm -f "$tmpfile"
}

