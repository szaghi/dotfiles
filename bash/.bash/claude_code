#!/usr/bin/env bash
# Claude Code Dual-Mode Setup: Local Ollama + Cloud Anthropic
#
# Workstation: 2x NVIDIA CUDA GPUs (12GB VRAM each) + 64GB system RAM
# Source from ~/.bashrc or ~/.zshrc

# ── GPU CONFIGURATION ─────────────────────────────────────────────────────────
# Identify GPUs with: nvidia-smi -L
export OLLAMA_GPU_UUID="GPU-63e0fc4d-bd54-cc22-532e-299518238d61"
export OLLAMA_GPU_ID="1"

# ── OLLAMA SERVER SETTINGS ────────────────────────────────────────────────────
export OLLAMA_HOST="127.0.0.1:11434"
export OLLAMA_KEEP_ALIVE="10m"
export OLLAMA_NUM_PARALLEL="1"
export OLLAMA_MAX_LOADED_MODELS="1"
export OLLAMA_FLASH_ATTENTION="1"       # Reduces VRAM, required for KV quant
export OLLAMA_KV_CACHE_TYPE="q8_0"      # Halves KV cache vs f16; use q4_0 for more savings

# ── MODEL DEFAULTS ────────────────────────────────────────────────────────────
# DEFAULT: qwen3-coder:latest — MoE 30B-A3B Q4_K_M, 18 GB, dual GPU
#   3B active params → inference speed of a 3B dense model, quality > 30B dense.
#   Avoid dense 30B+ models — RAM spill makes them 5-20x slower than MoE.
OLLAMA_DEFAULT_MODEL="qwen3-coder:latest"
OLLAMA_LIGHT_MODEL="deepseek-coder-v2:16b"   # Single-GPU (8.9 GB) — frees GPU 2 for HPC jobs

# Plan-mode: architect (planner) + executor (implementer)
OLLAMA_PLAN_MODEL="qwen3.5:27b"          # Architect: broad reasoning, designs approach
OLLAMA_EXEC_MODEL="qwen3-coder:latest"   # Executor: coding-specialized, fast MoE inference

# ── LOCAL CLAUDE FUNCTIONS ────────────────────────────────────────────────────

claude-local() {
    # Local Ollama — full context, default model (requires 2 GPUs)
    local model="${1:-$OLLAMA_DEFAULT_MODEL}"
    ANTHROPIC_AUTH_TOKEN=ollama \
    ANTHROPIC_BASE_URL="http://${OLLAMA_HOST}" \
    ANTHROPIC_API_KEY="" \
    CLAUDE_LOCAL_GPUS=2 \
    claude --model "$model" "${@:2}"
}

claude-local-light() {
    # Local Ollama — single-GPU model (8.9 GB); use when GPU 2 is needed for HPC jobs
    ANTHROPIC_AUTH_TOKEN=ollama \
    ANTHROPIC_BASE_URL="http://${OLLAMA_HOST}" \
    ANTHROPIC_API_KEY="" \
    CLAUDE_LOCAL_GPUS=1 \
    claude --model "$OLLAMA_LIGHT_MODEL" "$@"
}

claude-local-plan() {
    # Local plan mode: starts with architect for planning.
    # When ready to implement, switch mid-session with: /model plan-executor
    # Run ollama-plan-setup once to register the short-name aliases.
    printf '\n=== LOCAL PLAN MODE ===\n'
    printf '  ARCHITECT : plan-architect  (%s)\n' "$OLLAMA_PLAN_MODEL"
    printf '  EXECUTOR  : plan-executor   (%s)\n' "$OLLAMA_EXEC_MODEL"
    printf '\nSwitch to executor when ready:\n'
    printf '  /model plan-executor\n\n'
    ANTHROPIC_AUTH_TOKEN=ollama \
    ANTHROPIC_BASE_URL="http://${OLLAMA_HOST}" \
    ANTHROPIC_API_KEY="" \
    CLAUDE_LOCAL_GPUS=2 \
    claude --model "plan-architect" "$@"
}

ollama-plan-setup() {
    # Register short-name aliases for plan-mode models (run once after ollama-start)
    local tmpfile
    tmpfile=$(mktemp /tmp/Modelfile.XXXXXX)

    printf 'FROM %s\n' "$OLLAMA_PLAN_MODEL" > "$tmpfile"
    ollama create plan-architect -f "$tmpfile" \
        && printf 'Created: plan-architect → %s\n' "$OLLAMA_PLAN_MODEL"

    printf 'FROM %s\n' "$OLLAMA_EXEC_MODEL" > "$tmpfile"
    ollama create plan-executor -f "$tmpfile" \
        && printf 'Created: plan-executor  → %s\n' "$OLLAMA_EXEC_MODEL"

    rm -f "$tmpfile"
    printf '\nUse /model plan-executor inside a session to switch.\n'
}

claude-local-exec() {
    # Local executor only — skips planning, jumps straight to implementer model
    ANTHROPIC_AUTH_TOKEN=ollama \
    ANTHROPIC_BASE_URL="http://${OLLAMA_HOST}" \
    ANTHROPIC_API_KEY="" \
    CLAUDE_LOCAL_GPUS=2 \
    claude --model "$OLLAMA_EXEC_MODEL" "$@"
}

# ── CLOUD CLAUDE FUNCTIONS ────────────────────────────────────────────────────

claude-sonnet() { claude --model "sonnet" "$@"; }
claude-opus()   { claude --model "opus" "$@"; }
claude-plan()   { claude --permission-mode plan --model "opusplan" "$@"; }  # read-only plan (Opus) → auto-switch to Sonnet on execute

# ── OLLAMA SERVICE MANAGEMENT ─────────────────────────────────────────────────

ollama-start() {
    # Start Ollama pinned to a specific GPU (defaults to OLLAMA_GPU_UUID)
    local gpu="${OLLAMA_GPU_UUID:-${1:-$OLLAMA_GPU_ID}}"
    echo "Starting Ollama on GPU: $gpu"
    CUDA_VISIBLE_DEVICES="$gpu" ollama serve &
    disown
    sleep 2
    echo "Ollama running at http://${OLLAMA_HOST}"
}

ollama-start-multi() {
    # Start Ollama on ALL GPUs (needed for models > 12GB like qwen3.5:latest)
    echo "Starting Ollama on ALL GPUs — do not run HPC jobs concurrently"
    ollama serve &
    disown
    sleep 2
    echo "Ollama running at http://${OLLAMA_HOST}"
}

ollama-stop() {
    pkill -f "ollama serve" 2>/dev/null && echo "Ollama stopped." || echo "Ollama not running."
}

ollama-restart() {
    ollama-stop
    sleep 1
    ollama-start "$@"
}

ollama-status() {
    echo "=== Ollama Process ==="
    pgrep -a "ollama" || echo "Not running"
    echo ""
    echo "=== Loaded Models ==="
    curl -s "http://${OLLAMA_HOST}/api/ps" 2>/dev/null | python3 -m json.tool 2>/dev/null || echo "Cannot reach Ollama"
    echo ""
    echo "=== GPU Status ==="
    nvidia-smi --query-gpu=index,name,memory.used,memory.total,utilization.gpu \
               --format=csv,noheader,nounits 2>/dev/null || echo "nvidia-smi not available"
}

# ── MODEL HELPERS ─────────────────────────────────────────────────────────────

ollama-pull() {
    local model="${1:-$OLLAMA_DEFAULT_MODEL}"
    echo "Pulling: $model"
    ollama pull "$model"
}

ollama-create-64k() {
    # Create a 64K-capped variant — predictable RAM when running HPC jobs in parallel
    local model="${1:-$OLLAMA_DEFAULT_MODEL}"
    local variant="${model}-64k"
    local tmpfile
    tmpfile=$(mktemp /tmp/Modelfile.XXXXXX)
    cat > "$tmpfile" <<EOF
FROM $model
PARAMETER num_ctx 65536
EOF
    ollama create "$variant" -f "$tmpfile"
    rm -f "$tmpfile"
    echo "Created: $variant  (use with: claude-local $variant)"
}

ollama-models() {
    ollama list 2>/dev/null || echo "Ollama not running. Start with: ollama-start"
}

# ── QUICK REFERENCE ───────────────────────────────────────────────────────────

claude-help() {
    local b=$'\033[1m' r=$'\033[0m' dim=$'\033[2m'
    local sep="${dim}  ──────────────────────────────────────────────────────${r}"
    printf '\n'
    printf "  ${b}claude${r} — dual-mode quick reference\n"
    printf '\n'
    printf "  ${b}LOCAL${r}  Ollama · privacy-first\n"
    printf '%s\n' "$sep"
    printf '  %-28s%s\n' 'claude-local'               'qwen3-coder MoE 30B-A3B  dual GPU · default'
    printf '  %-28s%s\n' 'claude-local <model>'       'override model'
    printf '  %-28s%s\n' 'claude-local-light'         'deepseek-coder-v2 16B  single GPU · HPC-safe'
    printf '  %-28s%s\n' 'claude-local-plan'          'plan-architect → /model plan-executor to switch'
    printf '  %-28s%s\n' 'claude-local-exec'          'skip planning, run executor directly'
    printf '\n'
    printf "  ${b}CLOUD${r}  Anthropic API\n"
    printf '%s\n' "$sep"
    printf '  %-28s%s\n' 'claude'                     'subscription default'
    printf '  %-28s%s\n' 'claude-sonnet'              'force Sonnet'
    printf '  %-28s%s\n' 'claude-opus'                'force Opus'
    printf '  %-28s%s\n' 'claude-plan'                'read-only plan (Opus) → auto-switch to Sonnet'
    printf '\n'
    printf "  ${b}MID-SESSION${r}  inside Claude Code\n"
    printf '%s\n' "$sep"
    printf '  %-28s%s\n' '/model plan-executor'       'switch to executor (local plan mode)'
    printf '  %-28s%s\n' '/model sonnet'              'switch to Sonnet'
    printf '\n'
    printf "  ${b}OLLAMA${r}  service management\n"
    printf '%s\n' "$sep"
    printf '  %-28s%s\n' 'ollama-start'               'start on dedicated GPU'
    printf '  %-28s%s\n' 'ollama-start-multi'         'start on all GPUs'
    printf '  %-28s%s\n' 'ollama-stop / -restart'     'stop / restart'
    printf '  %-28s%s\n' 'ollama-status'              'GPU + loaded model status'
    printf '  %-28s%s\n' 'ollama-pull [model]'        'pull a model'
    printf '  %-28s%s\n' 'ollama-create-64k [model]'  'create 64K-capped variant'
    printf '  %-28s%s\n' 'ollama-plan-setup'          'register plan-architect / plan-executor aliases'
    printf '  %-28s%s\n' 'ollama-models'              'list available models'
    printf '\n'
}
