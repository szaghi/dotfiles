#!/usr/bin/env bash
# Claude Code: Cloud + Local inference setup
# Machine-specific overrides (GPU IDs, model paths, binary locations) live in
# ~/.bash/claude_code.local — deployed by the machine's own stow package.
# Source from ~/.bashrc or ~/.zshrc

# ── OLLAMA SETTINGS ───────────────────────────────────────────────────────────
export OLLAMA_HOST="127.0.0.1:11434"
export OLLAMA_KEEP_ALIVE="10m"
export OLLAMA_NUM_PARALLEL="1"
export OLLAMA_MAX_LOADED_MODELS="1"

# ── OLLAMA MODEL DEFAULTS (override in claude_code.local) ─────────────────────
OLLAMA_DEFAULT_MODEL="qwen2.5-coder:7b"

# ── LLAMA.CPP SETTINGS (override in claude_code.local) ───────────────────────
LLAMACPP_BIN="${LLAMACPP_BIN:-llama-server}"
LLAMACPP_HOST="127.0.0.1"
LLAMACPP_PORT="${LLAMACPP_PORT:-8080}"
LLAMACPP_MODELS_DIR="${LLAMACPP_MODELS_DIR:-${HOME}/models}"
LLAMACPP_DEFAULT_MODEL="${LLAMACPP_DEFAULT_MODEL:-}"
LLAMACPP_GPU_LAYERS="${LLAMACPP_GPU_LAYERS:--1}"
LLAMACPP_CTX="${LLAMACPP_CTX:-131072}"

# ── IK_LLAMA.CPP SETTINGS (override in claude_code.local) ────────────────────
# ik_llama.cpp is a llama.cpp fork with aggressive CPU/hybrid optimizations
# and new quant types (IQ4_KS, IQ2_KS). CLI is compatible with mainline.
# Runs on a distinct port (8081) so both servers can coexist if needed.
IKLLAMA_BIN="${IKLLAMA_BIN:-llama-server}"
IKLLAMA_HOST="127.0.0.1"
IKLLAMA_PORT="${IKLLAMA_PORT:-8081}"
IKLLAMA_GPU_LAYERS="${IKLLAMA_GPU_LAYERS:-99}"  # ik_llama.cpp parses -1 as 0 layers; use a large sentinel
IKLLAMA_CTX="${IKLLAMA_CTX:-131072}"
# IKLLAMA_MODELS_DIR and IKLLAMA_DEFAULT_MODEL fall back to LLAMACPP_* lazily
# at call time (see _lls_start_llama_generic) so overrides set in claude_code.local
# after this file are picked up correctly.

# ── LOCAL BACKEND DEFAULT (override in claude_code.local) ─────────────────────
LOCAL_DEFAULT_BACKEND="${LOCAL_DEFAULT_BACKEND:-ollama}"

# ── CLOUD FUNCTIONS ───────────────────────────────────────────────────────────

claude-sonnet() { claude --model "sonnet" "$@"; }
claude-opus()   { claude --model "opus"   "$@"; }
claude-plan()   { claude --permission-mode plan --model "opusplan" "$@"; }

OPENROUTER_DEFAULT_MODEL="qwen/qwen3.6-plus-preview:free"

claude-openrouter() {
    local model="${1:-$OPENROUTER_DEFAULT_MODEL}"
    local key="${OPENROUTER_API_KEY:-$(cat "$HOME/.openrouter-ai-key" 2>/dev/null)}"
    if [[ -z "$key" ]]; then
        printf 'Error: no OpenRouter API key (set OPENROUTER_API_KEY or ~/.openrouter-ai-key)\n' >&2
        return 1
    fi
    ANTHROPIC_AUTH_TOKEN="$key" \
    ANTHROPIC_BASE_URL="https://openrouter.ai/api" \
    ANTHROPIC_API_KEY="" \
    claude --model "$model" "${@:2}"
}

ZAI_DEFAULT_MODEL="glm-5-turbo"

claude-zai() {
    local model="${1:-$ZAI_DEFAULT_MODEL}"
    local key="${ZAI_API_KEY:-$(cat "$HOME/.z-ai-key" 2>/dev/null)}"
    if [[ -z "$key" ]]; then
        printf 'Error: no Z.ai API key (set ZAI_API_KEY or ~/.z-ai-key)\n' >&2
        return 1
    fi
    ANTHROPIC_AUTH_TOKEN="$key" \
    ANTHROPIC_BASE_URL="https://api.z.ai/api/anthropic" \
    ANTHROPIC_API_KEY="" \
    claude --model "$model" "${@:2}"
}

claude-zai-fast()    { claude-zai "glm-4.5-air" "$@"; }
claude-zai-turbo()   { claude-zai "glm-5-turbo" "$@"; }
claude-zai-premium() { claude-zai "glm-5.1"     "$@"; }

# ── LOCAL INFERENCE ENTRY POINT ───────────────────────────────────────────────
#
# claude-local [OPTIONS] [-- CLAUDE_ARGS...]
#
#   --backend ollama|llama   inference engine  (default: $LOCAL_DEFAULT_BACKEND)
#   --model   NAME           model name or GGUF path/alias
#   --ctx     TOKENS|32k|64k|128k   context window (default: per-backend default)
#   --gpus    1|2|all        GPU count for Ollama (default: all)
#   --no-autostart           do not start the server if not running
#   --no-autostop            do not stop the server when Claude exits
#
# By default claude-local auto-starts the correct backend before launching Claude
# and auto-stops it after Claude exits. If a different backend is already running
# it is stopped first.

claude-local() {
    local backend="$LOCAL_DEFAULT_BACKEND"
    local model="" ctx="" gpus="all"
    local autostart=1 autostop=1
    local -a claude_args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --backend)        backend="$2";    shift 2 ;;
            --model)          model="$2";      shift 2 ;;
            --ctx)            ctx="$2";        shift 2 ;;
            --gpus)           gpus="$2";       shift 2 ;;
            --no-autostart)   autostart=0;     shift   ;;
            --no-autostop)    autostop=0;      shift   ;;
            --)               shift; claude_args+=("$@"); break ;;
            *)                claude_args+=("$1"); shift ;;
        esac
    done

    # Validate backend
    case "$backend" in
        ollama|llama|ikllama) ;;
        *) printf 'Error: unknown backend "%s" (ollama|llama|ikllama)\n' "$backend" >&2; return 1 ;;
    esac

    if (( autostart )); then
        _local_autostart "$backend" "$model" "$ctx" "$gpus" || return 1
    fi

    local n_gpus
    case "$gpus" in
        all|2|"") n_gpus=2 ;;
        *)        n_gpus="$gpus" ;;
    esac

    local rc=0
    case "$backend" in
        ollama)
            local m="${model:-$OLLAMA_DEFAULT_MODEL}"
            ANTHROPIC_BASE_URL="http://${OLLAMA_HOST}" \
            CLAUDE_LOCAL_GPUS="$n_gpus" \
            claude --model "$m" "${claude_args[@]}"
            rc=$?
            ;;
        llama)
            if ! curl -sf --max-time 2 "http://${LLAMACPP_HOST}:${LLAMACPP_PORT}/health" &>/dev/null; then
                printf 'llama-server not reachable at %s:%s\n' "$LLAMACPP_HOST" "$LLAMACPP_PORT" >&2
                return 1
            fi
            local m="${model:-llama}"
            ANTHROPIC_BASE_URL="http://${LLAMACPP_HOST}:${LLAMACPP_PORT}" \
            CLAUDE_LOCAL_GPUS="$n_gpus" \
            claude --model "$m" "${claude_args[@]}"
            rc=$?
            ;;
        ikllama)
            if ! curl -sf --max-time 2 "http://${IKLLAMA_HOST}:${IKLLAMA_PORT}/health" &>/dev/null; then
                printf 'ik_llama-server not reachable at %s:%s\n' "$IKLLAMA_HOST" "$IKLLAMA_PORT" >&2
                return 1
            fi
            local m="${model:-ikllama}"
            ANTHROPIC_BASE_URL="http://${IKLLAMA_HOST}:${IKLLAMA_PORT}" \
            CLAUDE_LOCAL_GPUS="$n_gpus" \
            claude --model "$m" "${claude_args[@]}"
            rc=$?
            ;;
    esac

    if (( autostop )); then
        llm-local-server stop --backend "$backend"
    fi

    return $rc
}

# Internal: ensure the right backend is up, stopping the others if needed.
_local_autostart() {
    local backend="$1" model="$2" ctx="$3" gpus="$4"

    local ollama_up=0 llama_up=0 ikllama_up=0
    curl -sf --max-time 2 "http://${OLLAMA_HOST}/api/tags"                  &>/dev/null && ollama_up=1
    curl -sf --max-time 2 "http://${LLAMACPP_HOST}:${LLAMACPP_PORT}/health" &>/dev/null && llama_up=1
    curl -sf --max-time 2 "http://${IKLLAMA_HOST}:${IKLLAMA_PORT}/health"   &>/dev/null && ikllama_up=1

    _stop_other() {
        local self="$1"
        if [[ "$self" != "ollama"  ]] && (( ollama_up  )); then
            printf 'Ollama is running — stopping it\n'
            llm-local-server stop --backend ollama
        fi
        if [[ "$self" != "llama"   ]] && (( llama_up   )); then
            printf 'llama-server is running — stopping it\n'
            llm-local-server stop --backend llama
        fi
        if [[ "$self" != "ikllama" ]] && (( ikllama_up )); then
            printf 'ik_llama-server is running — stopping it\n'
            llm-local-server stop --backend ikllama
        fi
    }

    case "$backend" in
        ollama)
            _stop_other ollama
            if (( ! ollama_up )); then
                llm-local-server start --backend ollama --gpus "$gpus" \
                    ${model:+--model "$model"} || return 1
            fi
            ;;
        llama)
            _stop_other llama
            if (( ! llama_up )); then
                llm-local-server start --backend llama \
                    ${model:+--model "$model"} ${ctx:+--ctx "$ctx"} || return 1
            fi
            ;;
        ikllama)
            _stop_other ikllama
            if (( ! ikllama_up )); then
                llm-local-server start --backend ikllama \
                    ${model:+--model "$model"} ${ctx:+--ctx "$ctx"} || return 1
            fi
            ;;
    esac
}

# ── LLM LOCAL SERVER ──────────────────────────────────────────────────────────
#
# llm-local-server COMMAND [OPTIONS]
#
# Commands: start | stop | restart | status
#
# start options:
#   --backend ollama|llama   (default: $LOCAL_DEFAULT_BACKEND)
#   --model   NAME|PATH      model name (ollama) or GGUF path/alias (llama)
#   --ctx     TOKENS|32k|64k|128k
#   --gpus    1|2|all        Ollama only — GPU count (default: all)
#   [extra...]               passed through to the backend binary
#
# stop/restart/status options:
#   --backend ollama|llama   (default: $LOCAL_DEFAULT_BACKEND)

llm-local-server() {
    local cmd="${1:-}"; shift || true
    case "$cmd" in
        start)   _lls_start   "$@" ;;
        stop)    _lls_stop    "$@" ;;
        restart) _lls_restart "$@" ;;
        status)  _lls_status  "$@" ;;
        *)
            printf 'Usage: llm-local-server start|stop|restart|status [--backend ollama|llama] [options]\n' >&2
            return 1
            ;;
    esac
}

_lls_parse_backend() {
    # Writes into caller's $backend and $extra_args locals.
    # backend defaults to LOCAL_DEFAULT_BACKEND if not set by caller.
    [[ -z "${backend:-}" ]] && backend="$LOCAL_DEFAULT_BACKEND"
    extra_args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --backend) backend="$2"; shift 2 ;;
            *)         extra_args+=("$1"); shift ;;
        esac
    done
}

_lls_start() {
    local backend model="" ctx="" gpus="all"
    local -a extra_args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --backend) backend="$2"; shift 2 ;;
            --model)   model="$2";   shift 2 ;;
            --ctx)     ctx="$2";     shift 2 ;;
            --gpus)    gpus="$2";    shift 2 ;;
            --)        shift; extra_args+=("$@"); break ;;
            *)         extra_args+=("$1"); shift ;;
        esac
    done
    backend="${backend:-$LOCAL_DEFAULT_BACKEND}"

    case "$backend" in
        ollama)  _lls_start_ollama  "$model" "$gpus" "${extra_args[@]}" ;;
        llama)   _lls_start_llama   "$model" "$ctx"  "${extra_args[@]}" ;;
        ikllama) _lls_start_ikllama "$model" "$ctx"  "${extra_args[@]}" ;;
        *) printf 'Error: unknown backend "%s"\n' "$backend" >&2; return 1 ;;
    esac
}

_lls_start_ollama() {
    local model="$1" gpus="$2"; shift 2
    local -a extra_args=("$@")

    if curl -sf --max-time 2 "http://${OLLAMA_HOST}/api/tags" &>/dev/null; then
        printf 'Ollama already running at http://%s\n' "$OLLAMA_HOST"
        return 0
    fi

    printf 'Starting Ollama'
    case "$gpus" in
        all|2|"")
            printf ' on all GPUs\n'
            ollama serve "${extra_args[@]}" &>/tmp/ollama.log &
            ;;
        1)
            local gpu="${OLLAMA_GPU_UUID:-${OLLAMA_GPU_ID:-0}}"
            printf ' on GPU %s\n' "$gpu"
            CUDA_VISIBLE_DEVICES="$gpu" ollama serve "${extra_args[@]}" &>/tmp/ollama.log &
            ;;
        *)
            printf ' on GPU(s) %s\n' "$gpus"
            CUDA_VISIBLE_DEVICES="$gpus" ollama serve "${extra_args[@]}" &>/tmp/ollama.log &
            ;;
    esac
    disown

    _lls_wait_http "http://${OLLAMA_HOST}/api/tags" "Ollama" 60 || return 1

}

_lls_start_llama()   { _lls_start_llama_generic "llama"   "$@"; }
_lls_start_ikllama() { _lls_start_llama_generic "ikllama" "$@"; }

# Generic llama.cpp-family server starter. Drives both mainline llama.cpp and
# ik_llama.cpp (CLI-compatible fork). Flavor picks the env-var prefix:
#   llama   → LLAMACPP_BIN / LLAMACPP_HOST / LLAMACPP_PORT / ...
#   ikllama → IKLLAMA_BIN  / IKLLAMA_HOST  / IKLLAMA_PORT  / ...
_lls_start_llama_generic() {
    local flavor="$1" model_arg="$2" ctx="$3"; shift 3
    local -a extra_args=("$@")

    local bin host port gpu_layers default_ctx models_dir default_model label logfile
    case "$flavor" in
        llama)
            bin="$LLAMACPP_BIN"        host="$LLAMACPP_HOST"    port="$LLAMACPP_PORT"
            gpu_layers="$LLAMACPP_GPU_LAYERS"   default_ctx="$LLAMACPP_CTX"
            models_dir="$LLAMACPP_MODELS_DIR"   default_model="$LLAMACPP_DEFAULT_MODEL"
            label="llama-server"                logfile="/tmp/llama-server.log"
            ;;
        ikllama)
            bin="$IKLLAMA_BIN"         host="$IKLLAMA_HOST"     port="$IKLLAMA_PORT"
            gpu_layers="$IKLLAMA_GPU_LAYERS"    default_ctx="$IKLLAMA_CTX"
            models_dir="${IKLLAMA_MODELS_DIR:-$LLAMACPP_MODELS_DIR}"
            default_model="${IKLLAMA_DEFAULT_MODEL:-$LLAMACPP_DEFAULT_MODEL}"
            label="ik_llama-server"             logfile="/tmp/ikllama-server.log"
            ;;
        *) printf 'Error: unknown flavor "%s"\n' "$flavor" >&2; return 1 ;;
    esac

    if curl -sf --max-time 2 "http://${host}:${port}/health" &>/dev/null; then
        printf '%s already running at %s:%s\n' "$label" "$host" "$port"
        return 0
    fi

    if ! command -v "$bin" &>/dev/null && [[ ! -x "$bin" ]]; then
        printf 'Error: %s binary not found (tried: %s)\n' "$label" "$bin" >&2
        printf 'Set %s_BIN=/full/path/to/llama-server in claude_code.local\n' \
            "$(printf '%s' "$flavor" | tr '[:lower:]' '[:upper:]' | sed 's/ikllama/IKLLAMA/;s/llama/LLAMACPP/')" >&2
        return 1
    fi

    local model_path
    model_path=$(_llama_resolve_model_in "$model_arg" "$models_dir" "$default_model") || return 1

    local resolved_ctx
    resolved_ctx=$(_parse_ctx "${ctx:-$default_ctx}")

    printf 'Starting %s\n' "$label"
    printf '  model : %s\n' "$model_path"
    printf '  addr  : %s:%s\n' "$host" "$port"
    printf '  gpu   : %s layers  ctx: %s\n' "$gpu_layers" "$resolved_ctx"

    "$bin" \
        --model        "$model_path" \
        --alias        "$flavor" \
        --host         "$host" \
        --port         "$port" \
        --n-gpu-layers "$gpu_layers" \
        --ctx-size     "$resolved_ctx" \
        --flash-attn on \
        --jinja \
        "${extra_args[@]}" &>"$logfile" &
    disown

    _lls_wait_http "http://${host}:${port}/health" "$label" 120
}

_lls_stop() {
    local backend extra_args=()
    _lls_parse_backend "$@"

    case "$backend" in
        ollama)
            pkill -f "ollama serve" 2>/dev/null \
                && printf 'Ollama stopped.\n' \
                || printf 'Ollama not running.\n'
            ;;
        llama)   _lls_stop_llama_generic "llama"   "$LLAMACPP_PORT" ;;
        ikllama) _lls_stop_llama_generic "ikllama" "$IKLLAMA_PORT"  ;;
        *) printf 'Error: unknown backend "%s"\n' "$backend" >&2; return 1 ;;
    esac
}

# Both llama.cpp and ik_llama.cpp ship a binary called "llama-server" — we
# distinguish them by the --alias flag (llama vs ikllama) set at start, so
# pkill targets the exact process even when both are running.
_lls_stop_llama_generic() {
    local flavor="$1" port="$2"
    local label
    [[ "$flavor" == "ikllama" ]] && label="ik_llama-server" || label="llama-server"

    pkill -f "llama-server .*--alias ${flavor}( |$)" 2>/dev/null \
        || { printf '%s not running.\n' "$label"; return 0; }

    local i
    for i in 1 2 3 4 5; do
        ss -tlnp 2>/dev/null | grep -q ":${port}" || {
            printf '%s stopped.\n' "$label"; return 0
        }
        sleep 1
    done
    printf '%s stopped (port %s may still be in TIME_WAIT).\n' "$label" "$port"
}

_lls_status_llama_generic() {
    local flavor="$1" host="$2" port="$3" label="$4"
    printf '=== %s process ===\n' "$label"
    pgrep -af "llama-server .*--alias ${flavor}( |$)" || printf 'Not running\n'
    printf '\n=== Served model ===\n'
    curl -s "http://${host}:${port}/v1/models" 2>/dev/null \
        | python3 -m json.tool 2>/dev/null \
        || printf 'Cannot reach %s at %s:%s\n' "$label" "$host" "$port"
}

_lls_restart() {
    local backend extra_args=()
    _lls_parse_backend "$@"
    _lls_stop --backend "$backend"
    sleep 1
    _lls_start --backend "$backend" "${extra_args[@]}"
}

_lls_status() {
    local backend extra_args=()
    _lls_parse_backend "$@"

    case "$backend" in
        ollama)
            printf '=== Ollama process ===\n'
            pgrep -a "ollama" || printf 'Not running\n'
            printf '\n=== Loaded models ===\n'
            curl -s "http://${OLLAMA_HOST}/api/ps" 2>/dev/null \
                | python3 -m json.tool 2>/dev/null \
                || printf 'Cannot reach Ollama at http://%s\n' "$OLLAMA_HOST"
            ;;
        llama)   _lls_status_llama_generic "llama"   "$LLAMACPP_HOST" "$LLAMACPP_PORT" "llama-server"    ;;
        ikllama) _lls_status_llama_generic "ikllama" "$IKLLAMA_HOST"  "$IKLLAMA_PORT"  "ik_llama-server" ;;
        *) printf 'Error: unknown backend "%s"\n' "$backend" >&2; return 1 ;;
    esac

    printf '\n=== GPU status ===\n'
    nvidia-smi --query-gpu=index,name,memory.used,memory.total,utilization.gpu \
               --format=csv,noheader,nounits 2>/dev/null || printf 'nvidia-smi not available\n'
}

# ── OLLAMA MODEL UTILITIES ────────────────────────────────────────────────────

ollama-pull() {
    local model="${1:-$OLLAMA_DEFAULT_MODEL}"
    printf 'Pulling: %s\n' "$model"
    ollama pull "$model"
}

ollama-create() {
    # Create a context-capped variant: ollama-create [--ctx 32k|64k|128k|N] [model]
    local ctx=65536 model=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ctx) ctx=$(_parse_ctx "$2"); shift 2 ;;
            *)     model="$1"; shift ;;
        esac
    done
    model="${model:-$OLLAMA_DEFAULT_MODEL}"
    local label
    if   (( ctx <= 32768  )); then label="32k"
    elif (( ctx <= 65536  )); then label="64k"
    elif (( ctx <= 131072 )); then label="128k"
    else                           label="${ctx}"
    fi
    local variant="${model}-${label}"
    local tmpfile
    tmpfile=$(mktemp /tmp/Modelfile.XXXXXX)
    printf 'FROM %s\nPARAMETER num_ctx %s\n' "$model" "$ctx" > "$tmpfile"
    ollama create "$variant" -f "$tmpfile"
    rm -f "$tmpfile"
    printf 'Created: %s  (use with: claude-local --model %s)\n' "$variant" "$variant"
}

ollama-models() {
    local output
    output=$(ollama list 2>/dev/null) || { printf 'Ollama not running.\n' >&2; return 1; }
    local header lines
    header=$(printf '%s\n' "$output" | head -1)
    lines=$(printf '%s\n' "$output" | tail -n +2)
    [[ -z "$lines" ]] && { printf '%s\n' "$header"; printf '(no models)\n'; return 0; }
    printf '%s\n' "$header"
    local cat matched
    for cat in cloud embedding plan exec; do
        matched=$(printf '%s\n' "$lines" | awk -v c="$cat" '$1 ~ "[-:]"c"$"')
        [[ -n "$matched" ]] && printf '\n  [%s]\n%s\n' "$cat" "$matched"
    done
    matched=$(printf '%s\n' "$lines" | awk '$1 !~ "[-:](cloud|embedding|plan|exec)$"')
    [[ -n "$matched" ]] && printf '\n  [misc]\n%s\n' "$matched"
}

ollama-rename() {
    # Rename an Ollama model, bypassing the ollama cp inheritance quirk.
    if [[ $# -ne 2 ]]; then
        printf 'Usage: ollama-rename <old-name> <new-name>\n' >&2; return 1
    fi
    local old="$1" new="$2" tmpfile
    tmpfile=$(mktemp /tmp/Modelfile.XXXXXX)
    if ! ollama show "$old" --modelfile > "$tmpfile" 2>/dev/null && \
       ! ollama show --modelfile "$old"  > "$tmpfile" 2>/dev/null; then
        printf "Error: model '%s' not found\n" "$old" >&2
        ollama list >&2; rm -f "$tmpfile"; return 1
    fi
    if ollama create "$new" -f "$tmpfile"; then
        ollama rm "$old"
    else
        printf "Error: failed to create '%s' — '%s' was not removed.\n" "$new" "$old" >&2
        rm -f "$tmpfile"; return 1
    fi
    rm -f "$tmpfile"
}

# ── LLAMA.CPP MODEL UTILITIES ─────────────────────────────────────────────────

llama-models() {
    local hf_cache="${HF_HOME:-${HOME}/.cache/huggingface}/hub"
    local found=0
    if [[ -d "$LLAMACPP_MODELS_DIR" ]]; then
        local files
        files=$(find "$LLAMACPP_MODELS_DIR" -maxdepth 2 -name "*.gguf" 2>/dev/null | sort)
        if [[ -n "$files" ]]; then
            printf '\n  [%s]\n' "$LLAMACPP_MODELS_DIR"
            while IFS= read -r f; do
                local name="${f##*/}" size
                size=$(du -sh "$f" 2>/dev/null | cut -f1)
                if [[ -L "$f" ]]; then
                    printf '  %-12s  %-40s → %s\n' "$size" "$name" "$(readlink -f "$f")"
                else
                    printf '  %-12s  %s\n' "$size" "$name"
                fi
            done <<< "$files"
            found=1
        fi
    fi
    if [[ -d "$hf_cache" ]]; then
        local aliased
        aliased=$(find "$LLAMACPP_MODELS_DIR" -maxdepth 2 -name "*.gguf" -type l 2>/dev/null \
                  | xargs -r readlink -f | sort)
        local files
        files=$(find "$hf_cache" -name "*.gguf" 2>/dev/null | sort)
        if [[ -n "$files" ]]; then
            local printed=0
            while IFS= read -r f; do
                grep -qxF "$f" <<< "$aliased" && continue
                [[ $printed -eq 0 ]] && { printf '\n  [huggingface cache]\n'; printed=1; found=1; }
                printf '  %-12s  %s\n' "$(du -sh "$f" 2>/dev/null | cut -f1)" "$f"
            done <<< "$files"
        fi
    fi
    (( found )) || printf 'No GGUFs found in %s or huggingface cache\n' "$LLAMACPP_MODELS_DIR" >&2
}

llama-alias() {
    # llama-alias <name> <path>   — create symlink alias
    # llama-alias <name>          — remove alias
    if [[ $# -eq 0 ]]; then
        printf 'Usage: llama-alias <name> [path/to/model.gguf]\n' >&2; return 1
    fi
    local name="$1" target="${2:-}"
    local link="${LLAMACPP_MODELS_DIR}/${name}.gguf"
    mkdir -p "$LLAMACPP_MODELS_DIR"
    if [[ -z "$target" ]]; then
        [[ -L "$link" ]] && rm "$link" && printf 'Removed alias: %s\n' "$name" && return 0
        printf 'No alias "%s" in %s\n' "$name" "$LLAMACPP_MODELS_DIR" >&2; return 1
    fi
    target=$(realpath "$target" 2>/dev/null) || { printf 'Error: path not found: %s\n' "$2" >&2; return 1; }
    [[ -f "$target" ]] || { printf 'Error: not a file: %s\n' "$target" >&2; return 1; }
    [[ -L "$link" ]] && rm "$link"
    [[ -e "$link" ]] && { printf 'Error: %s exists and is not a symlink\n' "$link" >&2; return 1; }
    ln -s "$target" "$link"
    printf 'Alias created: %s → %s\n' "$name" "$target"
    printf 'Use with: claude-local --backend llama --model %s\n' "$name"
}

llama-info() {
    # Show GGUF metadata. No arg = currently loaded model (or default).
    local model_path
    if [[ $# -eq 0 ]]; then
        if curl -sf --max-time 2 "http://${LLAMACPP_HOST}:${LLAMACPP_PORT}/health" &>/dev/null; then
            local loaded
            loaded=$(curl -s "http://${LLAMACPP_HOST}:${LLAMACPP_PORT}/v1/models" \
                     | python3 -c "import sys,json; d=json.load(sys.stdin)['data']; print(d[0]['id'] if d else '')" 2>/dev/null)
            printf '=== Server: %s:%s (model: %s) ===\n' "$LLAMACPP_HOST" "$LLAMACPP_PORT" "${loaded:-unknown}"
            curl -s "http://${LLAMACPP_HOST}:${LLAMACPP_PORT}/props" \
                | python3 -m json.tool 2>/dev/null \
                || printf '(props endpoint unavailable)\n'
            printf '\n'
        fi
        model_path=$(_llama_resolve_model "") || return 1
    else
        model_path=$(_llama_resolve_model "$1") || return 1
    fi

    local gguf_py="${HOME}/llama.cpp-cuda/gguf-py"
    if [[ ! -d "$gguf_py" ]]; then
        printf 'gguf-py not found at %s\n' "$gguf_py" >&2; return 1
    fi

    printf '=== GGUF metadata: %s ===\n' "$model_path"
    PYTHONPATH="$gguf_py" python3 - "$model_path" <<'PYEOF'
import sys, collections
from pathlib import Path
from gguf.gguf_reader import GGUFReader
from gguf.constants import GGUFValueType

path = sys.argv[1]
r = GGUFReader(path)

SKIP_LARGE = {"tokenizer.ggml.tokens", "tokenizer.ggml.merges",
              "tokenizer.ggml.token_type", "tokenizer.chat_template",
              "tokenizer.ggml.scores"}

def _decode_field(fld):
    if not fld.types:
        return repr(fld.parts[fld.data[0]])
    t = fld.types[0]
    if t == GGUFValueType.STRING:
        return bytes(fld.parts[fld.data[0]]).decode("utf-8", errors="replace")
    if t == GGUFValueType.ARRAY:
        inner = fld.types[1] if len(fld.types) > 1 else None
        if inner == GGUFValueType.STRING:
            return [bytes(fld.parts[i]).decode("utf-8", errors="replace") for i in fld.data]
        raw = fld.parts[fld.data[0]]
        return raw.tolist() if hasattr(raw, "tolist") else repr(raw)
    raw = fld.parts[fld.data[0]]
    if hasattr(raw, "tolist"):
        v = raw.tolist()
        return v[0] if isinstance(v, list) and len(v) == 1 else v
    return repr(raw)

arch = ""
fields_out = {}
for key, field in r.fields.items():
    if key in SKIP_LARGE:
        continue
    try:
        val = _decode_field(field)
    except Exception:
        val = "<unreadable>"
    fields_out[key] = val
    if key == "general.architecture" and isinstance(val, str):
        arch = val

general  = {k: v for k, v in fields_out.items() if k.startswith("general.")}
arch_kv  = {k: v for k, v in fields_out.items()
            if arch and k.startswith(arch + ".") and "rope.dimension_sections" not in k}
token_kv = {k: v for k, v in fields_out.items()
            if k.startswith("tokenizer.") and k not in SKIP_LARGE}

def section(title, d):
    if not d: return
    print(f"\n  [{title}]")
    w = max(len(k) for k in d)
    for k, v in d.items():
        print(f"  {k:{w}}  {v}")

section("general", general)
section("architecture", arch_kv)
section("tokenizer", token_kv)
print(f"\n  chat_template  {'yes' if 'tokenizer.chat_template' in r.fields else 'no'}")

quant_counts = collections.Counter(t.tensor_type.name for t in r.tensors)
print(f"\n  [{len(r.tensors)} tensors]")
for qtype, count in sorted(quant_counts.items(), key=lambda x: -x[1]):
    print(f"  {count:4d}  {qtype}")
print(f"\n  file size  {Path(path).stat().st_size / 1e9:.2f} GB")
PYEOF
}

