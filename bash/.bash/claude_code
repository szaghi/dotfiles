_parse_ctx() {
    case "$1" in
        32k)  printf '32768'  ;;
        64k)  printf '65536'  ;;
        128k) printf '131072' ;;
        *)    printf '%s' "$1" ;;
    esac
}

_llama_resolve_model() {
    _llama_resolve_model_in "$1" "$LLAMACPP_MODELS_DIR" "$LLAMACPP_DEFAULT_MODEL"
}

_llama_resolve_model_in() {
    local model="${1:-$3}" models_dir="$2"
    if [[ -z "$model" ]]; then
        printf 'Error: no model — set default in claude_code.local or pass --model\n' >&2; return 1
    fi
    if   [[ -f "$model" ]];                             then printf '%s' "$model"
    elif [[ -f "${models_dir}/${model}" ]];             then printf '%s' "${models_dir}/${model}"
    elif [[ -f "${models_dir}/${model}.gguf" ]];        then printf '%s' "${models_dir}/${model}.gguf"
    else
        printf 'Error: model not found: %s\n' "$model" >&2; return 1
    fi
}

_lls_wait_http() {
    local url="$1" label="$2" timeout="${3:-60}"
    local i http_code
    for i in $(seq 1 "$timeout"); do
        http_code=$(curl -so /dev/null --max-time 2 -w "%{http_code}" "$url" 2>/dev/null)
        [[ "$http_code" == "200" ]] && { printf '%s ready.\n' "$label"; return 0; }
        [[ "$http_code" == "503" ]] && printf '\r  loading model... %ds' "$i"
        sleep 1
    done
    printf '\nTimeout after %ds waiting for %s\n' "$timeout" "$label" >&2
    return 1
}

