[user]
	name = Stefano Zaghi
	email = stefano.zaghi@gmail.com
[color]
  branch = always
  diff = always
  grep = always
  interactive = always
  pager = true
  showbranch = auto
  status = auto
  ui = always
[credential]
	helper = cache
[commit]
  template = ~/.git-templates/git_commit_message_template
	gpgsign = true
[diff]
	tool = vimdiff
[difftool]
	prompt = false
[merge]
  tool = vimdiff
[alias]
	d = difftool
	hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
	lg = log --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr %an)%Creset' --abbrev-commit --date=relative
	tree = !git lg --graph
	rebase-last-five = "!b=\"$(git branch --no-color | cut -c3-)\" ; h=\"$(git rev-parse $b)\" ; echo \"Current branch: $b $h\" ; c=\"$(git rev-parse $b~4)\" ; echo \"Recreating $b branch with initial commit $c ...\" ; git checkout --orphan new-start $c ; git commit -C $c ; git rebase --onto new-start $c $b ; git branch -d new-start ; git gc"
[core]
	editor = vim
	whitespace = space-before-tab,-indent-with-non-tab,trailing-space
[git-up "fetch"]
	all = true
[apply]
	whitespace = fix
[github]
	user = szaghi
[init]
	defaultBranch = main
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[tag]
	gpgsign = true

# Machine-specific overrides (signingkey, etc.) — deployed by the machine's stow package
[include]
	path = ~/.gitconfig.local
