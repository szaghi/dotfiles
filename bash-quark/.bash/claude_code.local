# claude_code.local — quark (Chuwi Minibook X N150, Intel iGPU, 16 GB RAM)
# Sourced at the end of ~/.bash/claude_code by the base file.
# No CUDA/nvidia-smi — CPU inference only (or Intel OpenCL if available).

# ── OLLAMA MODEL DEFAULTS ─────────────────────────────────────────────────────
# Keep total RAM under ~8 GB to leave headroom for the OS and browser.
# Q4_K_M quant at 7B fits in ~5 GB; 3B fits in ~2.5 GB.
OLLAMA_DEFAULT_MODEL="qwen2.5-coder:7b"
OLLAMA_LIGHT_MODEL="qwen2.5-coder:3b"    # Use when RAM pressure is high
OLLAMA_PLAN_MODEL="qwen2.5-coder:7b"
OLLAMA_EXEC_MODEL="qwen2.5-coder:7b"

# ── LLAMA.CPP ─────────────────────────────────────────────────────────────────
# CPU-only inference — no GPU layers
LLAMACPP_GPU_LAYERS="${LLAMACPP_GPU_LAYERS:-0}"
# Smaller context to limit RAM usage
LLAMACPP_CTX="${LLAMACPP_CTX:-8192}"
# Default model: small GGUF that fits in CPU RAM
LLAMACPP_DEFAULT_MODEL="${LLAMACPP_DEFAULT_MODEL:-${HOME}/models/qwen2.5-coder-7b-q4_k_m.gguf}"
